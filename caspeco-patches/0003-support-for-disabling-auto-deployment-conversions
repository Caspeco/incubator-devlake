+
+package models
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+)
+
+func TestIsConvertGithubDeploymentEnabled(t *testing.T) {
+	t.Run("nil scope config defaults to enabled", func(t *testing.T) {
+		var sc *GithubScopeConfig
+		assert.True(t, sc.IsConvertGithubDeploymentEnabled())
+	})
+
+	t.Run("nil field defaults to enabled for backward compatibility", func(t *testing.T) {
+		sc := &GithubScopeConfig{}
+		assert.True(t, sc.IsConvertGithubDeploymentEnabled())
+	})
+
+	t.Run("explicit true remains enabled", func(t *testing.T) {
+		enabled := true
+		sc := &GithubScopeConfig{ConvertGithubDeployment: &enabled}
+		assert.True(t, sc.IsConvertGithubDeploymentEnabled())
+	})
+
+	t.Run("explicit false disables conversion", func(t *testing.T) {
+		enabled := false
+		sc := &GithubScopeConfig{ConvertGithubDeployment: &enabled}
+		assert.False(t, sc.IsConvertGithubDeploymentEnabled())
+	})
+}
